{
  "radar": {
    "dimensions": [
      { "id": "yapping", "label": "Yapping", "formula": "clamp((avg_user_msg_length / 200) * 60 + (total_user_messages / total_conversations) * 20, 0, 100)", "description": "How much you talk to AI" },
      { "id": "googling", "label": "Googling", "formula": "clamp(question_ratio * 100, 0, 100)", "description": "How much you ask questions" },
      { "id": "grinding", "label": "Grinding", "formula": "clamp((avg_turns_per_conversation / 20) * 50 + retry_ratio * 50, 0, 100)", "description": "How much you iterate" },
      { "id": "shipping", "label": "Shipping", "formula": "clamp(code_block_ratio * 60 + task_completion_ratio * 40, 0, 100)", "description": "How much you actually produce" },
      { "id": "tunnel_vision", "label": "Tunnel Vision", "formula": "clamp((max_conversation_turns / 50) * 100, 0, 100)", "description": "Deepest rabbit hole" },
      { "id": "plot_armor", "label": "Plot Armor", "formula": "clamp(100 - error_followup_ratio * 100, 0, 100)", "description": "How well you recover" }
    ]
  },
  "metrics": {
    "question_keywords": {
      "zh": ["什么", "怎么", "如何", "为什么", "吗", "能不能", "可以吗", "是不是", "哪个", "哪些", "多少"],
      "en": ["what", "how", "why", "can you", "could you", "is it", "are there", "which", "where"]
    },
    "code_block_pattern": "```",
    "task_keywords": {
      "zh": ["帮我", "请", "生成", "写一个", "创建", "修改", "实现"],
      "en": ["create", "write", "build", "implement", "generate", "make", "fix"]
    },
    "retry_patterns": {
      "zh": ["重新", "再来", "不对", "换一个", "重做"],
      "en": ["try again", "redo", "not right", "wrong", "different"]
    },
    "short_conversation_turns": 3,
    "long_message_chars": 200,
    "night_hour_start": 20,
    "night_hour_end": 4,
    "multi_topic_min_signals": 3
  },
  "thresholds": {
    "min_conversations": 3,
    "min_messages": 20,
    "min_notice": "Not enough data yet. Keep chatting!"
  }
}
